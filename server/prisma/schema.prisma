generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Keyword {
  id              Int              @id @default(autoincrement())
  term            String           @unique
  enabled         Boolean          @default(true)
  hotspotKeywords HotspotKeyword[]
  eventKeywords   HotspotEventKeyword[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model KeywordExpansion {
  id                    Int      @id @default(autoincrement())
  normalizedKeyword     String   @unique
  originalKeyword       String
  expandedKeywordsJson  String
  provider              String?
  model                 String?
  source                String   @default("rule_fallback")
  lastUsedAt            DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([lastUsedAt])
}

model Setting {
  id                      Int      @id @default(autoincrement())
  scope                   String   @default("AI 编程")
  aiProvider              String   @default("openrouter")
  scanIntervalMinutes     Int      @default(30)
  autoScanEnabled         Boolean  @default(false)
  emailEnabled            Boolean  @default(false)
  websocketEnabled        Boolean  @default(true)
  recipientEmail          String?
  relevanceThreshold      Int      @default(70)
  importanceThreshold     String   @default("high")
  bingSourceEnabled       Boolean  @default(true)
  googleNewsSourceEnabled Boolean  @default(true)
  hackerNewsSourceEnabled Boolean  @default(true)
  twitterSourceEnabled    Boolean  @default(true)
  bilibiliSourceEnabled   Boolean  @default(true)
  weiboSourceEnabled      Boolean  @default(true)
  sogouSourceEnabled      Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model Hotspot {
  id                Int              @id @default(autoincrement())
  title             String
  snippet           String?
  url               String
  canonicalUrl      String?
  sourceType        String
  sourceAuthor      String?
  sourcePublishedAt DateTime?
  engagementJson    String?
  dedupeKey         String           @unique
  titleNormalized   String
  aiIsReal          Boolean?
  aiRelevance       Int?
  aiImportance      String?
  aiSummary         String?
  aiEvidence        String?
  auditStatus       String?
  aiConfidence      Int?
  trustScore        Int?
  sourceQualityScore Int?
  auditFlagsJson    String?
  auditVersion      String?
  corroborationCount Int             @default(0)
  discoveredAt      DateTime         @default(now())
  keywords          HotspotKeyword[]
  notifications     NotificationLog[]

  @@index([discoveredAt])
  @@index([sourceType])
  @@index([aiImportance])
  @@index([aiIsReal])
  @@index([auditStatus])
  @@index([trustScore])
  @@index([titleNormalized])
  @@index([canonicalUrl])
}

model HotspotKeyword {
  id        Int      @id @default(autoincrement())
  hotspotId Int
  keywordId Int
  createdAt DateTime @default(now())

  hotspot Hotspot @relation(fields: [hotspotId], references: [id], onDelete: Cascade)
  keyword Keyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@unique([hotspotId, keywordId])
}

model NotificationLog {
  id           Int      @id @default(autoincrement())
  hotspotId     Int
  channel       String
  status        String
  recipient     String?
  errorMessage  String?
  sentAt        DateTime @default(now())

  hotspot Hotspot @relation(fields: [hotspotId], references: [id], onDelete: Cascade)

  @@index([channel, status])
  @@index([sentAt])
}

model HotspotEvent {
  id                     Int                   @id @default(autoincrement())
  eventFingerprint       String                @unique
  title                  String
  summary                String?
  primaryUrl             String?
  primarySourceType      String?
  primarySourceAuthor    String?
  sourcePublishedAt      DateTime?
  contentType            String                @default("news")
  verificationStatus     String                @default("needs_review")
  relevanceScore         Int                   @default(0)
  evidenceScore          Int                   @default(0)
  corroborationScore     Int                   @default(0)
  contradictionScore     Int                   @default(0)
  sourceQualityScore     Int                   @default(0)
  trustScore             Int                   @default(0)
  heatScore              Int                   @default(0)
  matchedKeywordsJson    String?
  relevanceReason        String?
  keywordMentioned       Boolean?
  importance             String                @default("low")
  independentSourceCount Int                   @default(0)
  hasOfficialSource      Boolean               @default(false)
  riskFlagsJson          String?
  auditEvidenceJson      String?
  auditVersion           String                @default("deep-verify-v1")
  firstSeenAt            DateTime              @default(now())
  lastSeenAt             DateTime              @updatedAt
  verifiedAt             DateTime?
  sourceItems            HotspotSourceItem[]
  claims                 EventClaim[]
  keywords               HotspotEventKeyword[]
  feedback               VerificationFeedback[]
  notifications          EventNotificationLog[]
  scanInboxItems         LatestScanInboxItem[]

  @@index([verificationStatus])
  @@index([trustScore])
  @@index([heatScore])
  @@index([relevanceScore])
  @@index([sourcePublishedAt])
  @@index([lastSeenAt])
}

model HotspotEventKeyword {
  id        Int          @id @default(autoincrement())
  eventId   Int
  keywordId Int
  createdAt DateTime     @default(now())
  event     HotspotEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  keyword   Keyword      @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@unique([eventId, keywordId])
  @@index([keywordId])
}

model HotspotSourceItem {
  id                Int             @id @default(autoincrement())
  eventId           Int
  title             String
  snippet           String?
  bodyText          String?
  bodyHash          String?
  originalUrl       String
  canonicalUrl      String
  publisherDomain   String?
  publisherName     String?
  sourceType        String
  discoverySourceType String?
  sourceAuthor      String?
  sourcePublishedAt DateTime?
  engagementJson    String?
  fetchStatus       String          @default("metadata_only")
  fetchError        String?
  isOfficial        Boolean         @default(false)
  isSyndicated      Boolean         @default(false)
  sourceGroup       String?
  sourceAuthorityScore Int          @default(50)
  authorityReason  String?
  officialEntity   String?
  independenceGroup String?
  evidenceFlagsJson String?
  discoveredAt      DateTime        @default(now())
  lastSeenAt        DateTime        @updatedAt
  event             HotspotEvent    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  claimEvidence     ClaimEvidence[]

  @@unique([eventId, canonicalUrl])
  @@index([canonicalUrl])
  @@index([publisherDomain])
  @@index([sourceType])
  @@index([discoverySourceType])
  @@index([independenceGroup])
  @@index([bodyHash])
}

model EventClaim {
  id         Int             @id @default(autoincrement())
  eventId    Int
  claimKey   String
  statement  String
  status     String          @default("unverified")
  confidence Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  event      HotspotEvent    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  evidence   ClaimEvidence[]

  @@unique([eventId, claimKey])
  @@index([status])
}

model ClaimEvidence {
  id           Int               @id @default(autoincrement())
  claimId      Int
  sourceItemId Int
  stance       String
  excerpt      String?
  confidence   Int               @default(0)
  createdAt    DateTime          @default(now())
  claim        EventClaim        @relation(fields: [claimId], references: [id], onDelete: Cascade)
  sourceItem   HotspotSourceItem @relation(fields: [sourceItemId], references: [id], onDelete: Cascade)

  @@unique([claimId, sourceItemId])
  @@index([stance])
}

model SourceHealth {
  id             Int       @id @default(autoincrement())
  sourceType     String    @unique
  status         String    @default("unknown")
  lastAttemptAt  DateTime?
  lastSuccessAt  DateTime?
  durationMs     Int?
  httpStatus     Int?
  candidateCount Int       @default(0)
  filteredCount  Int       @default(0)
  errorMessage   String?
  updatedAt      DateTime  @updatedAt
  createdAt      DateTime  @default(now())
}

model VerificationFeedback {
  id        Int          @id @default(autoincrement())
  eventId   Int
  type      String
  note      String?
  createdAt DateTime     @default(now())
  event     HotspotEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, type])
}

model EventNotificationLog {
  id           Int          @id @default(autoincrement())
  eventId      Int
  channel      String
  status       String
  recipient    String?
  errorMessage String?
  sentAt       DateTime     @default(now())
  event        HotspotEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, channel, status])
  @@index([sentAt])
}

model LatestScanInbox {
  id          Int                   @id
  scanJobId   String?
  trigger     String?
  scannedAt   DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  items       LatestScanInboxItem[]
}

model LatestScanInboxItem {
  id         Int             @id @default(autoincrement())
  inboxId    Int
  eventId    Int
  isRead     Boolean         @default(false)
  capturedAt DateTime        @default(now())
  inbox      LatestScanInbox @relation(fields: [inboxId], references: [id], onDelete: Cascade)
  event      HotspotEvent    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([inboxId, eventId])
  @@index([inboxId, isRead])
  @@index([capturedAt])
}
